<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:id="@+id/top_info_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/card_form_bg"
        android:paddingTop="44dp"
        android:paddingBottom="16dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♠ ROYAL TABLE ♠"
            android:textColor="#C9A84C"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_top_player"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👑 King: Loading..."
            android:textColor="#C9A84C"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_lobby_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Balance: $0"
            android:textColor="#F0F0F0"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ===== ONLINE POKER SECTION ===== -->
    <LinearLayout
        android:id="@+id/multiplayer_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_form_bg"
        android:padding="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        app:layout_constraintTop_toBottomOf="@id/top_info_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ONLINE POKER"
            android:textColor="#C9A84C"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="14dp"
            android:layout_gravity="center_horizontal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <EditText
                android:id="@+id/et_room_id"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"
                android:background="@drawable/input_dark"
                android:hint="Room ID"
                android:inputType="number"
                android:textAlignment="center"
                android:layout_marginEnd="10dp"
                android:textColor="#F0F0F0"
                android:textColorHint="#555555"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_join_room"
                android:layout_width="90dp"
                android:layout_height="50dp"
                android:text="JOIN"
                android:background="@drawable/btn_gold"
                android:textColor="#0D0D0D"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_create_room"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="CREATE NEW TABLE"
            android:background="@drawable/btn_gold"
            android:layout_marginTop="10dp"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.08"
            android:stateListAnimator="@null"
            android:elevation="0dp" />

    </LinearLayout>

    <!-- ===== LOGOUT (fixed at bottom) ===== -->
    <Button
        android:id="@+id/btn_lobby_logout"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="LOGOUT"
        android:background="@drawable/input_dark"
        android:textColor="#FF4444"
        android:textStyle="bold"
        android:textSize="14sp"
        android:letterSpacing="0.1"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="16dp"
        android:stateListAnimator="@null"
        android:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== GAMES LIST ===== -->
    <ScrollView
        android:id="@+id/scroll_buttons"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/multiplayer_layout"
        app:layout_constraintBottom_toTopOf="@id/btn_lobby_logout"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btn_play_poker"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="♠  POKER VS BOT"
                android:background="@drawable/btn_gold"
                android:textColor="#0D0D0D"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

            <Button
                android:id="@+id/btn_lobby_blackjack"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="🂡  BLACKJACK"
                android:background="@drawable/card_form_bg"
                android:textColor="#F0F0F0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

            <Button
                android:id="@+id/btn_lobby_roulette"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="🎰  ROULETTE"
                android:background="@drawable/card_form_bg"
                android:textColor="#F0F0F0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

            <Button
                android:id="@+id/btn_lobby_slots"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="🎲  SLOTS"
                android:background="@drawable/card_form_bg"
                android:textColor="#F0F0F0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

            <Button
                android:id="@+id/btn_goto_tictactoe"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="✕○  WIN $1000 (X/O)"
                android:background="@drawable/card_form_bg"
                android:textColor="#F0F0F0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>