<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.cardview.widget.CardView
        android:id="@+id/name_plate"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/txt_player_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_player_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$1,000"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/player_cards_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:elevation="5dp"
        app:layout_constraintTop_toBottomOf="@id/name_plate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-15dp">

        <ImageView
            android:id="@+id/img_card1"
            android:layout_width="48dp"
            android:layout_height="68dp"
            android:src="@drawable/card_back"
            android:layout_marginEnd="2dp" />

        <ImageView
            android:id="@+id/img_card2"
            android:layout_width="48dp"
            android:layout_height="68dp"
            android:src="@drawable/card_back" />
    </LinearLayout>

    <TextView
        android:id="@+id/txt_status_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHECK"
        android:textColor="#FF0000"
        android:textSize="20sp"
        android:textStyle="bold"
        android:elevation="10dp"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/player_cards_container"
        app:layout_constraintBottom_toBottomOf="@id/player_cards_container"
        app:layout_constraintStart_toStartOf="@id/player_cards_container"
        app:layout_constraintEnd_toEndOf="@id/player_cards_container" />

</androidx.constraintlayout.widget.ConstraintLayout>