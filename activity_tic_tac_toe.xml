<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/login_background"
    android:padding="16dp">

    <!-- כותרת -->
    <TextView
        android:id="@+id/txt_tictac_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WIN $1000!"
        android:textColor="#C9A84C"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Beat the AI to claim your prize"
        android:textColor="#888888"
        android:textSize="14sp"
        android:layout_marginBottom="28dp" />

    <!-- לוח משחק -->
    <GridLayout
        android:id="@+id/grid_tictac"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="3"
        android:background="@drawable/card_form_bg"
        android:padding="8dp">

        <Button android:id="@+id/btn_0" android:layout_width="100dp" android:layout_height="100dp" android:textSize="40sp" android:layout_margin="3dp" android:background="@drawable/input_dark" android:textColor="#C9A84C" android:textStyle="bold" android:stateListAnimator="@null" android:elevation="0dp"/>
        <Button android:id="@+id/btn_1" android:layout_width="100dp" android:layout_height="100dp" android:textSize="40sp" android:layout_margin="3dp" android:background="@drawable/input_dark" android:textColor="#C9A84C" android:textStyle="bold" android:stateListAnimator="@null" android:elevation="0dp"/>
        <Button android:id="@+id/btn_2" android:layout_width="100dp" android:layout_height="100dp" android:textSize="40sp" android:layout_margin="3dp" android:background="@drawable/input_dark" android:textColor="#C9A84C" android:textStyle="bold" android:stateListAnimator="@null" android:elevation="0dp"/>
        <Button android:id="@+id/btn_3" android:layout_width="100dp" android:layout_height="100dp" android:textSize="40sp" android:layout_margin="3dp" android:background="@drawable/input_dark" android:textColor="#C9A84C" android:textStyle="bold" android:stateListAnimator="@null" android:elevation="0dp"/>
        <Button android:id="@+id/btn_4" android:layout_width="100dp" android:layout_height="100dp" android:textSize="40sp" android:layout_margin="3dp" android:background="@drawable/input_dark" android:textColor="#C9A84C" android:textStyle="bold" android:stateListAnimator="@null" android:elevation="0dp"/>
        <Button android:id="@+id/btn_5" android:layout_width="100dp" android:layout_height="100dp" android:textSize="40sp" android:layout_margin="3dp" android:background="@drawable/input_dark" android:textColor="#C9A84C" android:textStyle="bold" android:stateListAnimator="@null" android:elevation="0dp"/>
        <Button android:id="@+id/btn_6" android:layout_width="100dp" android:layout_height="100dp" android:textSize="40sp" android:layout_margin="3dp" android:background="@drawable/input_dark" android:textColor="#C9A84C" android:textStyle="bold" android:stateListAnimator="@null" android:elevation="0dp"/>
        <Button android:id="@+id/btn_7" android:layout_width="100dp" android:layout_height="100dp" android:textSize="40sp" android:layout_margin="3dp" android:background="@drawable/input_dark" android:textColor="#C9A84C" android:textStyle="bold" android:stateListAnimator="@null" android:elevation="0dp"/>
        <Button android:id="@+id/btn_8" android:layout_width="100dp" android:layout_height="100dp" android:textSize="40sp" android:layout_margin="3dp" android:background="@drawable/input_dark" android:textColor="#C9A84C" android:textStyle="bold" android:stateListAnimator="@null" android:elevation="0dp"/>

    </GridLayout>

    <!-- כפתור יציאה -->
    <Button
        android:id="@+id/btn_tictac_exit"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="EXIT"
        android:layout_marginTop="32dp"
        android:background="@drawable/input_dark"
        android:textColor="#FF4444"
        android:textStyle="bold"
        android:textSize="15sp"
        android:letterSpacing="0.1"
        android:stateListAnimator="@null"
        android:elevation="0dp" />

</LinearLayout>