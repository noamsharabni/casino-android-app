<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background"
    android:clipChildren="false">

  <!-- ===== כפתור יציאה ===== -->
  <ImageButton
      android:id="@+id/btn_exit_poker"
      android:layout_width="50dp"
      android:layout_height="50dp"
      android:layout_marginStart="16dp"
      android:layout_marginTop="40dp"
      android:background="?attr/selectableItemBackgroundBorderless"
      android:src="@android:drawable/ic_menu_close_clear_cancel"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      app:tint="#FF4444" />

  <!-- ===== טיימר ===== -->
  <TextView
      android:id="@+id/txt_timer"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="40dp"
      android:text="TIMER"
      android:textColor="#F0F0F0"
      android:textSize="22sp"
      android:textStyle="bold"
      android:visibility="invisible"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent" />

  <!-- ===== Room ID ===== -->

  <!-- ===== שולחן פוקר ===== -->
  <TextView
      android:id="@+id/txt_room_display"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:text="OFFLINE MODE"
      android:textColor="#C9A84C"
      android:textSize="16sp"
      android:textStyle="bold"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintHorizontal_bias="0.47"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/txt_timer" />

  <View
      android:id="@+id/poker_table"
      android:layout_width="0dp"
      android:layout_height="320dp"
      android:layout_marginHorizontal="12dp"
      android:background="@drawable/poker_table_shape"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintVertical_bias="0.4" />

  <!-- ===== הכרזת שלב ===== -->
  <TextView
      android:id="@+id/txt_round_announcer"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textColor="#C9A84C"
      android:textSize="40sp"
      android:textStyle="bold"
      android:visibility="gone"
      android:elevation="25dp"
      android:gravity="center"
      android:shadowColor="#000000"
      android:shadowDx="2"
      android:shadowDy="2"
      android:shadowRadius="4"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <!-- ===== שחקן עליון (יריב) ===== -->
  <include
      android:id="@+id/slot_top_center"
      layout="@layout/poker_player_top"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintBottom_toTopOf="@id/poker_table"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_marginBottom="-45dp" />

  <!-- ===== שחקן תחתון (אני) ===== -->
  <include
      android:id="@+id/slot_bottom_me"
      layout="@layout/poker_player_bottom"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/poker_table"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_marginTop="-45dp" />

  <!-- ===== POT ===== -->
  <TextView
      android:id="@+id/txt_pot"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="POT: $0"
      android:textColor="#C9A84C"
      android:textSize="26sp"
      android:textStyle="bold"
      app:layout_constraintBottom_toTopOf="@id/community_cards_layout"
      app:layout_constraintEnd_toEndOf="@id/poker_table"
      app:layout_constraintStart_toStartOf="@id/poker_table"
      android:layout_marginBottom="12dp" />

  <!-- ===== קלפי קהילה ===== -->
  <LinearLayout
      android:id="@+id/community_cards_layout"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      app:layout_constraintBottom_toBottomOf="@id/poker_table"
      app:layout_constraintEnd_toEndOf="@id/poker_table"
      app:layout_constraintStart_toStartOf="@id/poker_table"
      app:layout_constraintTop_toTopOf="@id/poker_table">

    <ImageView android:layout_width="65dp" android:layout_height="100dp" android:layout_margin="3dp" android:src="@drawable/card_back" />
    <ImageView android:layout_width="65dp" android:layout_height="100dp" android:layout_margin="3dp" android:src="@drawable/card_back" />
    <ImageView android:layout_width="65dp" android:layout_height="100dp" android:layout_margin="3dp" android:src="@drawable/card_back" />
    <ImageView android:layout_width="65dp" android:layout_height="100dp" android:layout_margin="3dp" android:src="@drawable/card_back" />
    <ImageView android:layout_width="65dp" android:layout_height="100dp" android:layout_margin="3dp" android:src="@drawable/card_back" />

  </LinearLayout>

  <!-- ===== AI Card ===== -->
  <androidx.cardview.widget.CardView
      android:id="@+id/card_ai_message"
      android:layout_width="160dp"
      android:layout_height="wrap_content"
      android:layout_marginBottom="8dp"
      android:visibility="gone"
      app:cardBackgroundColor="#161616"
      app:cardCornerRadius="12dp"
      app:cardElevation="6dp"
      app:layout_constraintBottom_toTopOf="@id/fab_gemini"
      app:layout_constraintStart_toStartOf="@id/fab_gemini">

    <TextView
        android:id="@+id/txt_ai_recommendation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="בודק קלפים..."
        android:textColor="#C9A84C"
        android:textSize="13sp"
        android:textStyle="bold" />

  </androidx.cardview.widget.CardView>

  <!-- ===== FAB Gemini ===== -->
  <com.google.android.material.floatingactionbutton.FloatingActionButton
      android:id="@+id/fab_gemini"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="16dp"
      android:layout_marginBottom="16dp"
      app:backgroundTint="#C9A84C"
      app:srcCompat="@android:drawable/ic_menu_help"
      app:tint="#0D0D0D"
      app:fabSize="normal"
      app:layout_constraintBottom_toTopOf="@id/poker_controls"
      app:layout_constraintStart_toStartOf="parent" />

  <!-- ===== ALL-IN FAB ===== -->
  <com.google.android.material.floatingactionbutton.FloatingActionButton
      android:id="@+id/btn_all_in"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginEnd="16dp"
      android:layout_marginBottom="16dp"
      app:backgroundTint="#C9A84C"
      app:srcCompat="@android:drawable/ic_menu_upload"
      app:tint="#0D0D0D"
      app:fabSize="normal"
      app:layout_constraintBottom_toTopOf="@id/poker_controls"
      app:layout_constraintEnd_toEndOf="parent" />

  <!-- ===== CONTROLS ===== -->
  <LinearLayout
      android:id="@+id/poker_controls"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@drawable/card_form_bg"
      android:padding="16dp"
      android:orientation="vertical"
      app:layout_constraintBottom_toBottomOf="parent">

    <EditText
        android:id="@+id/et_bet_amount"
        android:layout_width="120dp"
        android:layout_height="45dp"
        android:layout_gravity="center"
        android:background="@drawable/input_dark"
        android:hint="סכום"
        android:inputType="number"
        android:textAlignment="center"
        android:layout_marginBottom="10dp"
        android:textColor="#F0F0F0"
        android:textColorHint="#555555"
        android:padding="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4">

      <!-- FOLD -->
      <Button
          android:id="@+id/btn_fold"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_weight="1"
          android:text="FOLD"
          android:backgroundTint="#CC2222"
          android:layout_margin="2dp"
          android:textColor="#FFFFFF"
          android:textStyle="bold"
          android:textSize="13sp"
          android:stateListAnimator="@null"
          android:elevation="0dp" />

      <!-- CHECK -->
      <Button
          android:id="@+id/btn_check"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_weight="1"
          android:text="CHECK"
          android:background="@drawable/input_dark"
          android:layout_margin="2dp"
          android:textColor="#F0F0F0"
          android:textStyle="bold"
          android:textSize="13sp"
          android:stateListAnimator="@null"
          android:elevation="0dp" />

      <!-- CALL -->
      <Button
          android:id="@+id/btn_call"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_weight="1"
          android:text="CALL"
          android:background="@drawable/btn_gold"
          android:layout_margin="2dp"
          android:textStyle="bold"
          android:textSize="13sp"
          android:stateListAnimator="@null"
          android:elevation="0dp" />

      <!-- BET -->
      <Button
          android:id="@+id/btn_bet_raise"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_weight="1"
          android:text="BET"
          android:background="@drawable/btn_gold"
          android:layout_margin="2dp"
          android:textColor="#0D0D0D"
          android:textStyle="bold"
          android:textSize="13sp"
          android:stateListAnimator="@null"
          android:elevation="0dp" />

    </LinearLayout>
  </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>